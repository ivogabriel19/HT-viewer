---
import MainLayout from "../layouts/Layout.astro"

const res = await fetch("http://localhost:3000/api/team")
const teams = await res.json()
const team = teams[0]
---

<MainLayout title="Team Detail">
  <h2>{team.TeamName}</h2>

  <img src={team.LogoURL} class="logo" />

  <div class="card">
    <p><strong>ID:</strong> {team.TeamID}</p>
    <p><strong>Fundado:</strong> {team.FoundedDate}</p>
    <p><strong>País:</strong> {team.Country?.CountryName}</p>
    <p><strong>Región:</strong> {team.Region?.RegionName}</p>
    <p><strong>Liga:</strong> {team.League?.LeagueName}</p>
    <p><strong>División:</strong> {team.LeagueLevelUnit?.LeagueLevelUnitName}</p>
    <p><strong>Estadio:</strong> {team.Arena?.ArenaName}</p>
    <p><strong>Ranking Global:</strong> {team.PowerRating?.GlobalRanking}</p>
    <p><strong>Ranking Liga:</strong> {team.PowerRating?.LeagueRanking}</p>
    <p><strong>Fanclub:</strong> {team.Fanclub?.FanclubSize}</p>
    <p><strong>Victorias:</strong> {team.NumberOfVictories}</p>
  </div>
</MainLayout>

<style>
  .logo {
    width: 120px;
    margin-bottom: 15px;
  }

  .card {
    background: #2f3e46;
    padding: 15px;
    border-radius: 6px;
    border: 1px solid #52796f;
    max-width: 500px;
  }
</style>