---
import MainLayout from "../layouts/Layout.astro"

const cookie = Astro.request.headers.get("cookie") ?? ""

const res = await fetch("http://localhost:3000/api/team/summary", {
  headers: { Cookie: cookie },
})

if (res.status === 401) return Astro.redirect("/login")

const payload = await res.json()
if (!res.ok) throw new Error(`API error: ${payload.error ?? res.status}`)

const { team, topPlayer, newestPlayer } = payload
---

<MainLayout title="Home">
  <div class="team-header">
    <div>
      <h2>{team.TeamName}</h2>
      <p>{team.Region?.RegionName} — {team.League?.LeagueName}</p>
    </div>
  </div>

  <div class="grid">
    <div class="card">
      <h3>Team Info</h3>
      <p><strong>Estadio:</strong> {team.Arena?.ArenaName}</p>
      <p><strong>División:</strong> {team.LeagueLevelUnit?.LeagueLevelUnitName}</p>
      <p><strong>Power:</strong> {team.PowerRating?.PowerRating}</p>
      <p><strong>Victorias:</strong> {team.NumberOfVictories?.["#text"] ?? team.NumberOfVictories}</p>
    </div>

    <div class="card">
      <h3>🔥 Mejor jugador (TSI)</h3>
      <p>{topPlayer.PlayerName}</p>
      <p>TSI: {topPlayer.TSI}</p>
    </div>

    <div class="card">
      <h3>🆕 Última incorporación</h3>
      <p>{newestPlayer.PlayerName}</p>
      <p>ID: {newestPlayer.PlayerID}</p>
    </div>
  </div>
</MainLayout>

<style>
  .team-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
  }

  .card {
    background: #2f3e46;
    padding: 15px;
    border-radius: 6px;
    border: 1px solid #52796f;
  }

  h3 {
    margin-top: 0;
    color: #84a98c;
  }
</style>
