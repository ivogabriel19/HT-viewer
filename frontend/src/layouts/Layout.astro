---
const { title = "HT Viewer" } = Astro.props

const cookie = Astro.request.headers.get("cookie") ?? ""
const authRes = await fetch("http://localhost:3000/auth/status", { headers: { Cookie: cookie } })
const { authenticated } = await authRes.json()
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
  </head>

  <body>
    <header class="header">
      <h1>HT Viewer</h1>
      <nav>
        <a href="/">Home</a>
        <a href="/team">Team details</a>
        <a href="/players">Players</a>
        {authenticated
          ? <a href="http://localhost:3000/auth/logout" id="logout" class="auth-link logout">Desconectar</a>
          : <a href="/login" class="auth-link login">Conectar Hattrick</a>
        }
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>
  </body>
</html>

<script>
  document.getElementById("logout")?.addEventListener("click", async (e) => {
    e.preventDefault()
    await fetch("http://localhost:3000/auth/logout", { method: "POST", credentials: "include" })
    window.location.href = "/login"
  })
</script>

<style>
  body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #1f2a30;
    color: #e6e6e6;
  }

  .header {
    background: #2f3e46;
    padding: 12px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #84a98c;
  }

  .header h1 {
    margin: 0;
    font-size: 18px;
    color: #cad2c5;
  }

  nav a {
    margin-left: 15px;
    color: #84a98c;
    text-decoration: none;
    font-weight: bold;
  }

  nav a:hover {
    text-decoration: underline;
  }

  .auth-link {
    margin-left: 20px;
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 13px;
  }

  .auth-link.login {
    background: #84a98c;
    color: #1f2a30 !important;
  }

  .auth-link.logout {
    background: #52796f;
    color: #cad2c5 !important;
  }

  .container {
    padding: 20px;
  }
</style>
